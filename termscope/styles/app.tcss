Screen {
    layout: vertical;
}

#header {
    height: 3;
    padding: 1 2;
    background: #2b3440;
    color: $text;
}

#main {
    height: 1fr;
}

#metrics-pane,
#process-pane {
    width: 1fr;
    height: 1fr;
    padding: 1;
    background: #11161d;
}

#metrics-stack {
    height: 1fr;
}

#metrics,
#distro-art,
#top-processes,
#processes-table {
    border: round #5f7a95;
    background: #11161d;
    color: $text;
}

#metrics {
    height: 1fr;
    min-height: 8;
    padding: 1;
}

#distro-art {
    height: auto;
    min-height: 9;
    margin-top: 1;
    padding: 1 2;
    content-align: left top;
}

#top-processes,
#processes-table {
    height: 1fr;
    padding: 1;
    scrollbar-size-vertical: 1;
    scrollbar-size-horizontal: 1;
    scrollbar-background: #05080c;
    scrollbar-background-hover: #0b1017;
    scrollbar-background-active: #0b1017;
    scrollbar-color: #7b93ad;
    scrollbar-color-hover: #a8cfff;
    scrollbar-color-active: #f3f8ff;
    scrollbar-corner-color: #05080c;
}

#processes-title {
    height: 1;
    padding: 0 2;
    color: #84a9d8;
}

#footer {
    height: 1;
    padding: 0 2;
    background: $panel;
    color: $text-muted;
}

.theme-default #header {
    background: #2b3440;
}

.theme-default #metrics-pane,
.theme-default #process-pane,
.theme-default #metrics,
.theme-default #distro-art,
.theme-default #top-processes,
.theme-default #processes-table {
    background: #11161d;
    border: round #5f7a95;
}

.theme-default #processes-title {
    color: #84a9d8;
}

.theme-default #top-processes,
.theme-default #processes-table {
    scrollbar-background: #05080c;
    scrollbar-background-hover: #0b1017;
    scrollbar-background-active: #0b1017;
    scrollbar-color: #7b93ad;
    scrollbar-color-hover: #a8cfff;
    scrollbar-color-active: #f3f8ff;
    scrollbar-corner-color: #05080c;
}

.theme-arch #header,
.theme-alpine #header {
    background: #13314b;
}

.theme-arch #metrics-pane,
.theme-arch #process-pane,
.theme-arch #metrics,
.theme-arch #distro-art,
.theme-arch #top-processes,
.theme-arch #processes-table,
.theme-alpine #metrics-pane,
.theme-alpine #process-pane,
.theme-alpine #metrics,
.theme-alpine #distro-art,
.theme-alpine #top-processes,
.theme-alpine #processes-table {
    background: #0d1722;
    border: round #3ea0ff;
}

.theme-arch #processes-title,
.theme-alpine #processes-title {
    color: #6ab7ff;
}

.theme-arch #top-processes,
.theme-arch #processes-table,
.theme-alpine #top-processes,
.theme-alpine #processes-table {
    scrollbar-background: #040c13;
    scrollbar-background-hover: #0d1a28;
    scrollbar-background-active: #0d1a28;
    scrollbar-color: #4096ee;
    scrollbar-color-hover: #6fc0ff;
    scrollbar-color-active: #e6f4ff;
    scrollbar-corner-color: #040c13;
}

.theme-cachyos #header {
    background: #2b123f;
}

.theme-cachyos #metrics-pane,
.theme-cachyos #process-pane,
