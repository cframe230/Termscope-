ConfirmKillScreen {
    align: center middle;
    background: rgba(0, 0, 0, 0.65);
}

#confirm-kill-dialog {
    width: 50;
    height: auto;
    padding: 1 2;
    border: round $accent;
    background: $surface;
    color: $text;
    content-align: center middle;
}

#confirm-kill-dialog.critical {
    border: round $error;
    background: $error-darken-3;
    color: $text;
}
