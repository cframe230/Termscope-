    scrollbar-background-hover: #1b0d29;
    scrollbar-background-active: #1b0d29;
    scrollbar-color: #a45cff;
    scrollbar-color-hover: #ca95ff;
    scrollbar-color-active: #f3e8ff;
    scrollbar-corner-color: #0d0613;
}

